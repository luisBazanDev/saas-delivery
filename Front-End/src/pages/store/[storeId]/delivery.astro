---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import ProtectedRoute from '../../../components/auth/ProtectedRoute'
import DeliveryView from '../../../components/pages/DeliveryView'
import AppLayout from '../../../components/layout/AppLayout'

const storeId = Astro.params.storeId || ''
---

<BaseLayout title="App de Entregas">
<ProtectedRoute client:load requiredRole="STORE_DELIVERY">
  <AppLayout client:load title="App de Entregas" storeId={storeId}>
    <DeliveryView client:load storeId={storeId} />
  </AppLayout>
</ProtectedRoute>
</BaseLayout>
