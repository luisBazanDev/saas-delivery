---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import ProtectedRoute from '../../../components/auth/ProtectedRoute'
import StoreDashboard from '../../../components/pages/StoreDashboard'
import AppLayout from '../../../components/layout/AppLayout'

const storeId = Astro.params.storeId || ''
---

<BaseLayout title="Dashboard del Local">
<ProtectedRoute client:load requiredRoles={['STORE_ADMIN', 'STORE_MANAGER']}>
  <AppLayout client:load title="Dashboard del Local" storeId={storeId}>
    <StoreDashboard client:load storeId={storeId} />
  </AppLayout>
</ProtectedRoute>
</BaseLayout>
