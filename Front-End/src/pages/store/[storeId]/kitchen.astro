---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import ProtectedRoute from '../../../components/auth/ProtectedRoute'
import KitchenView from '../../../components/pages/KitchenView'
import AppLayout from '../../../components/layout/AppLayout'

const storeId = Astro.params.storeId || ''
---

<BaseLayout title="Órdenes en Cocina">
<ProtectedRoute client:load requiredRole="STORE_MANAGER">
  <AppLayout client:load title="Órdenes en Cocina" storeId={storeId}>
    <KitchenView client:load storeId={storeId} />
  </AppLayout>
</ProtectedRoute>
</BaseLayout>
