---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import ProtectedRoute from '../../../components/auth/ProtectedRoute'
import OrderKanban from '../../../components/pages/OrderKanban'
import AppLayout from '../../../components/layout/AppLayout'

const storeId = Astro.params.storeId || ''
---

<BaseLayout title="Tablero de Órdenes">
<ProtectedRoute client:load requiredRoles={['STORE_ADMIN', 'STORE_MANAGER']}>
  <AppLayout client:load title="Tablero de Órdenes" storeId={storeId}>
    <OrderKanban client:load storeId={storeId} />
  </AppLayout>
</ProtectedRoute>
</BaseLayout>
