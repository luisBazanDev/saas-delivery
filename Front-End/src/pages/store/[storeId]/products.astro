---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import ProtectedRoute from '../../../components/auth/ProtectedRoute'
import ProductManagement from '../../../components/pages/ProductManagement'
import AppLayout from '../../../components/layout/AppLayout'

const storeId = Astro.params.storeId || ''
---

<BaseLayout title="Gestión de Productos">
<ProtectedRoute client:load requiredRole="STORE_ADMIN">
  <AppLayout client:load title="Gestión de Productos" storeId={storeId}>
    <ProductManagement client:load storeId={storeId} />
  </AppLayout>
</ProtectedRoute>
</BaseLayout>
